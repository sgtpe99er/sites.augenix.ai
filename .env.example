# Same Supabase project as app.augenix.ai (read-only access for the Sites renderer).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Shared secret used by the Dashboard to call POST /api/revalidate after a publish.
# Must match the value of `SITES_REVALIDATE_SECRET` set in the Dashboard project.
REVALIDATE_SECRET=replace-with-a-long-random-string
